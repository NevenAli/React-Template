{
  "mcpServers": {
    "figma": {
      "command": "npx",
      "args": ["-y", "@jayarrowz/mcp-figma"],
      "env": {
        "FIGMA_API_KEY": "${FIGMA_API_KEY}"
      }
    },
    "stitch": {
      "command": "npx",
      "args": ["-y", "stitch-mcp"],
      "env": {
        "GOOGLE_CLOUD_PROJECT": "${GOOGLE_CLOUD_PROJECT}",
        "STITCH_API_KEY": "${STITCH_API_KEY}"
      }
    }
  }
}
